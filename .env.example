# ==============================================================================
# web-agency-backend-api — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# ==============================================================================

# --- Application ---
NODE_ENV=development
PORT=3500
NPM_PACKAGE_VERSION=1.0.0

# --- CORS / Frontend ---
# The URL of the frontend app (used in CORS allow-list and email links)
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Database ---
# MongoDB connection string. This service stores Contact, Inquiry, and Newsletter records.
MONGODB_URI=mongodb://localhost:27017/web-agency

# --- JWT (must match JWT_ACCESS_SECRET in user-auth-service) ---
# Tokens are ISSUED by user-auth-service and only VERIFIED here. Never sign tokens here.
JWT_ACCESS_SECRET=change_me_at_least_32_characters_long_access
JWT_ISSUER=user-auth-service
JWT_AUDIENCE=dashboard-app

# --- Email Microservice ---
# Base URL of the email microservice (no trailing slash)
EMAIL_SERVICE_URL=http://localhost:3100

# SMTP fallback — only used if the email microservice is unreachable
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASS=your-mailtrap-password

FROM_EMAIL=noreply@youragency.com
FROM_NAME=Web Agency

# --- Admin ---
ADMIN_EMAIL=admin@youragency.com

# --- External Microservices ---
AUTH_SERVICE_URL=http://localhost:4002
LEAD_SERVICE_URL=http://localhost:4003
FILE_UPLOAD_SERVICE_URL=http://localhost:4001

# --- Tenant configuration ---
# TENANT_ID is injected as x-tenant-id on every proxied/downstream request.
# TENANCY_ENABLED mirrors the setting in downstream services — keep them in sync.
# true  → tenant header is enforced (TENANT_ID injected when client omits header).
# false → tenant header is not injected; downstream services operate without tenant scoping.
TENANCY_ENABLED=true
# Your tenant slug — must match DEFAULT_TENANT_ID in user-auth-service, lead-microservice,
# file-upload-service, and sms-delivery-service.
TENANT_ID=easydev

# --- Logging ---
ENABLE_LOGGING=true
LOG_LEVEL=info

# ==============================================================================
# PAYMENT GATEWAYS
# Leave a gateway's keys unset to disable it (the routes will return 503).
# ==============================================================================

# --- Razorpay (INR / India) ---
# Create at https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Razorpay Webhook Secret — set in dashboard → Webhooks → Add New Webhook
# Webhook URL: https://yourdomain.com/api/payments/webhooks/razorpay
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# --- Stripe (USD / International) ---
# Create at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret — obtain from:
# Stripe Dashboard → Developers → Webhooks → Add Endpoint
# Webhook URL: https://yourdomain.com/api/payments/webhooks/stripe
# Events to listen for: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# PRODUCT PROVISIONING
# After a successful payment, web-agency-backend-api calls the appropriate
# product's API to create the customer's account.
# ==============================================================================

# --- EasyDev AI Communication Platform ---
# Base URL of the AI Communication NestJS backend (no trailing slash).
# Must include the API prefix, e.g. http://localhost:3001/api/v1
COMMUNICATION_API_URL=http://localhost:3001/api/v1

# SALES_API_KEY configured on the AI Communication backend.
# Used as the X-Api-Key header when calling /onboarding/create-account.
# Keep this secret — it must never be exposed to the browser.
COMMUNICATION_API_KEY=your_communication_sales_api_key
# Set to "true" to disable rotating log files (e.g. on serverless platforms)
DISABLE_FILE_LOGGING=false

# --- Performance ---
# Enable Node.js cluster mode (one worker per CPU core)
CLUSTER_MODE=false
# Per-request timeout in ms before the connection is forcibly closed
REQUEST_TIMEOUT=30000
# Graceful shutdown wait in ms
SHUTDOWN_TIMEOUT=10000

# --- Docs ---
# Set to "true" to expose Swagger UI at /api/docs
ENABLE_SWAGGER=true
