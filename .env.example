# ==============================================================================
# web-agency-backend-api — Environment Variables
# Copy this file to .env and fill in the values for your environment.
#
# SHARED SECRET CONTRACTS (must match across services):
#   JWT_ACCESS_SECRET     = JWT_SECRET in multi-tannet-auth-services
#   COMMUNICATION_API_KEY = SALES_API_KEY in ai-automation-communication
#   PAYMENT_SERVICE_API_KEY (plaintext) ← SHA-256 hash → API_KEY_HASH in payment-microservice
# ==============================================================================

# --- Application --------------------------------------------------------------
NODE_ENV=development
PORT=3301
NPM_PACKAGE_VERSION=1.0.0

# --- CORS / Frontend ----------------------------------------------------------
# Public marketing site — used in CORS allow-list and public-facing email links
FRONTEND_URL=http://localhost:3300
# All allowed CORS origins: marketing site + admin dashboard + ai-comm frontend.
# [prod] include both apex and www variants: https://example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3300,http://localhost:3305,http://localhost:3301

# --- Database -----------------------------------------------------------------
# MongoDB — stores Contact, Inquiry, Newsletter, and Lead records only.
MONGODB_URI=mongodb://localhost:3352/web-agency

# --- JWT ----------------------------------------------------------------------
# Tokens are ISSUED by multi-tannet-auth-services and VERIFIED here only.
# Never sign tokens in this service.
#
# Option A — RS256 asymmetric (recommended for production):
#   Copy JWT_PUBLIC_KEY from multi-tannet-auth-services/.env (base64-encoded SPKI PEM).
#   Leave JWT_ACCESS_SECRET blank when JWT_PUBLIC_KEY is set.
JWT_PUBLIC_KEY=
#
# Option B — HS256 shared secret (dev/single-node only):
#   Must equal JWT_SECRET in multi-tannet-auth-services.
JWT_ACCESS_SECRET=CHANGE_ME_must_match_JWT_SECRET_in_iam_service
#
# JWT_ISSUER must exactly match JWT_ISSUER in multi-tannet-auth-services.
# Default in IAM: https://iam-service.easydev.in
JWT_ISSUER=https://iam-service.easydev.in
JWT_AUDIENCE=dashboard-app

# --- Email Microservice -------------------------------------------------------
EMAIL_SERVICE_URL=https://notification.example.com
NOTIFICATION_SERVICE_HEALTH_URL=https://notification.example.com/v1/health
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
FROM_EMAIL=noreply@youragency.com
FROM_NAME=Your Platform

# --- Admin --------------------------------------------------------------------
ADMIN_EMAIL=admin@youragency.com

# --- External Microservices ---------------------------------------------------
# multi-tannet-auth-services — used for BOTH:
#   1. Proxy routes  (/api/auth, /api/rbac, /api/users, /api/tenants, ...)
#   2. SSO token generation  (POST /api/v1/iam/sso/generate)
#   3. Privileged IAM calls (user provisioning, grant creation)
# One service, one URL — no separate IAM_SERVICE_URL needed.
# IAM default local port: 3304
AUTH_SERVICE_URL=http://localhost:3304

# IAM service-account credentials used for privileged provisioning calls.
# Must match the service account seeded in multi-tannet-auth-services.
IAM_ADMIN_EMAIL=service-account-iam@iam.local
IAM_ADMIN_PASSWORD=CHANGE_ME_iam_service_account_password
IAM_ADMIN_JWT=
IAM_TENANT_SLUG=your_tenant_slug

FILE_UPLOAD_SERVICE_URL=http://localhost:3310
FILE_UPLOAD_SERVICE_HEALTH_URL=https://files.example.com/health

# --- Tenant -------------------------------------------------------------------
# Preferred tenant identifier; injected as x-tenant-slug when client omits it.
TENANT_SLUG=your_tenant_slug

# Injected as x-tenant-id on every proxied request when the client omits it.
# Must match the tenant slug registered in multi-tannet-auth-services.
# Add TENANCY_ENABLED=false only to fully disable tenant scoping everywhere.
TENANT_ID=your_tenant_slug

# --- Lead / CRM ---------------------------------------------------------------
# Admin dashboard URL used in proposal/contract email deep-links.
# NOTE: Different port from FRONTEND_URL (marketing site).
DASHBOARD_URL=http://localhost:3305

# --- Redis (optional) ---------------------------------------------------------
REDIS_ENABLED=false
REDIS_URL=redis://localhost:3351

# --- Logging ------------------------------------------------------------------
ENABLE_LOGGING=true
LOG_LEVEL=info
DISABLE_FILE_LOGGING=false

# --- Performance --------------------------------------------------------------
CLUSTER_MODE=false
REQUEST_TIMEOUT=30000
SHUTDOWN_TIMEOUT=10000

# --- Docs ---------------------------------------------------------------------
ENABLE_SWAGGER=true

# --- Payment Gateways ---------------------------------------------------------
# Only the Razorpay PUBLIC key belongs here — returned to the frontend checkout UI.
# ALL secrets (key_secret, webhook_secrets, Stripe keys) live in payment-microservice.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx

# --- AI Communication Platform ------------------------------------------------
# Full versioned API base URL. Include the /api/v1 prefix.
# AI Communication backend default local port: 3303
COMMUNICATION_URL=http://localhost:3303/api/v1

# Service-to-service API key — sent as X-Api-Key header.
# Must equal SALES_API_KEY in ai-automation-communication backend.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COMMUNICATION_API_KEY=CHANGE_ME_must_match_SALES_API_KEY_in_ai_comm

# IAM application/tenant slugs for AI Communication provisioning.
# Must match values registered in multi-tannet-auth-services.
COMMUNICATION_IAM_APPLICATION_SLUG=easydev-ai-communication
COMMUNICATION_IAM_TENANT_SLUG=your_tenant_slug
COMMUNICATION_IAM_DEFAULT_ROLE=member

# --- Payment Microservice -----------------------------------------------------
# Payment microservice default local port: 3302
PAYMENT_SERVICE_URL=http://localhost:3302

# Plaintext key — payment-microservice stores SHA-256(this) as API_KEY_HASH.
# Generate the pair:
#   node -e "const k=require('crypto').randomBytes(32).toString('hex'); console.log('KEY='+k+'\nHASH='+require('crypto').createHash('sha256').update(k).digest('hex'))"
PAYMENT_SERVICE_API_KEY=CHANGE_ME_plaintext_key_sha256_goes_into_API_KEY_HASH_in_payment
