{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug web-agency-backend-api (nodemon)",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["run", "debug:dev"],
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"restart": true,
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"]
		},
		{
			"name": "Debug web-agency-backend-api (single run)",
			"type": "node",
			"request": "launch",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["run", "debug"],
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env",
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"skipFiles": ["<node_internals>/**", "**/node_modules/**"]
		}
	]
}
