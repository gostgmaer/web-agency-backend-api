        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const r = pm.response.json();",
                  "  if (r.data?.accessToken)  pm.collectionVariables.set('authToken', r.data.accessToken);",
                  "  if (r.data?.refreshToken) pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
                  "  pm.test('Login successful', () => pm.expect(r.success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Password123!\"\n}",
