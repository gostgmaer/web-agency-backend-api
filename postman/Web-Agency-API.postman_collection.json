{
  "info": {
    "name": "Web Development Agency API",
    "description": "Complete API collection for Web Development Agency backend service",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', response.data.token);",
                  "    pm.test('Login successful', function () {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.token).to.exist;",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@webagency.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login with admin credentials to get JWT token"
          }
        },
        {
          "name": "Get Admin Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            },
            "description": "Get current admin profile information"
          }
        },
        {
          "name": "Admin Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Logout admin user"
          }
        }
      ]
    },
    {
      "name": "Newsletter",
      "item": [
        {
          "name": "Subscribe to Newsletter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/newsletter/subscribe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "newsletter", "subscribe"]
            },
            "description": "Subscribe email to newsletter (sends welcome email)"
          }
        },
        {
          "name": "Unsubscribe from Newsletter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/newsletter/unsubscribe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "newsletter", "unsubscribe"]
            },
            "description": "Unsubscribe email from newsletter"
          }
        },
        {
          "name": "Get Newsletter Subscribers (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/newsletter?page=1&limit=10&status=active",
              "host": ["{{baseUrl}}"],
              "path": ["api", "newsletter"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "active"
                }
              ]
            },
            "description": "Get paginated list of newsletter subscribers (Admin only)"
          }
        },
        {
          "name": "Delete Newsletter Subscriber (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/newsletter/{{subscriberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "newsletter", "{{subscriberId}}"]
            },
            "description": "Delete newsletter subscriber by ID (Admin only)"
          }
        }
      ]
    },
    {
      "name": "Blog",
      "item": [
        {
          "name": "Get Published Blogs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/blogs?page=1&limit=10&category=tech&search=web",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "tech"
                },
                {
                  "key": "search",
                  "value": "web"
                }
              ]
            },
            "description": "Get paginated list of published blogs with optional filtering"
          }
        },
        {
          "name": "Get Blog by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/blogs/{{blogSlug}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs", "{{blogSlug}}"]
            },
            "description": "Get single blog post by slug (increments view count)"
          }
        },
        {
          "name": "Create Blog (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Getting Started with Modern Web Development\",\n  \"slug\": \"getting-started-modern-web-development\",\n  \"content\": \"<p>This is the full content of the blog post...</p>\",\n  \"excerpt\": \"Learn the fundamentals of modern web development with this comprehensive guide.\",\n  \"featuredImage\": \"https://example.com/image.jpg\",\n  \"categories\": [\"web-development\", \"tutorial\"],\n  \"tags\": [\"javascript\", \"react\", \"nodejs\"],\n  \"isPublished\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/blogs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs"]
            },
            "description": "Create new blog post (Admin only)"
          }
        },
        {
          "name": "Update Blog (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Blog Title\",\n  \"content\": \"<p>Updated content...</p>\",\n  \"isPublished\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/blogs/{{blogId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs", "{{blogId}}"]
            },
            "description": "Update existing blog post (Admin only)"
          }
        },
        {
          "name": "Delete Blog (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/blogs/{{blogId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs", "{{blogId}}"]
            },
            "description": "Soft delete blog post (Admin only)"
          }
        }
      ]
    },
    {
