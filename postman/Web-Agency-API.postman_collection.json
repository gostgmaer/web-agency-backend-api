    {
      "name": "Leads — Submit (Public)",
      "description": "**Proxied → lead-microservice** (no auth required)\n\nThis is the **single endpoint for contact forms AND project inquiries**.\n\n- Contact form → set `\"category\": \"General Inquiry\"`\n- Project inquiry → set `\"category\": \"Sales\"` and include `projectType`, `budget`, `timeline`\n\nThe `x-tenant-id` header is required by the lead-microservice.",
      "item": [
        {
          "name": "Submit — Contact Form",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  const id = r.data?.lead?._id || r.data?._id;",
                  "  if (id) pm.collectionVariables.set('leadId', id);",
                  "  pm.test('Lead submitted', () => pm.expect(r.success).to.be.true);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "your-tenant-id", "description": "Required by lead-microservice" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"+1234567890\",\n  \"subject\": \"Website enquiry\",\n  \"message\": \"Hi, I would like to know more about your services.\",\n  \"gdprConsent\": true,\n  \"category\": \"General Inquiry\",\n  \"preferredContactMethod\": \"email\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads", "submit"]
            },
            "description": "Replaces the old `POST /api/contact` endpoint. Submit a general contact message."
          }
        },
        {
          "name": "Submit — Project Inquiry",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  const id = r.data?.lead?._id || r.data?._id;",
                  "  if (id) pm.collectionVariables.set('leadId', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "your-tenant-id" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Sarah\",\n  \"lastName\": \"Johnson\",\n  \"email\": \"sarah@acme.com\",\n  \"phone\": \"+1987654321\",\n  \"subject\": \"E-commerce website project\",\n  \"message\": \"We need a full e-commerce platform built from scratch.\",\n  \"gdprConsent\": true,\n  \"projectType\": \"ecommerce\",\n  \"budget\": \"25k-50k\",\n  \"timeline\": \"3-6months\",\n  \"category\": \"Sales\",\n  \"website\": \"https://acme.com\",\n  \"preferredContactMethod\": \"email\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads/submit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads", "submit"]
            },
            "description": "Replaces the old `POST /api/inquiry` endpoint. Submit a project inquiry with budget, timeline, and project type. Same route as the contact form — use `category: Sales` to distinguish."
          }
        }
      ]
    },
