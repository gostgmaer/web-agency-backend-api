    {
      "name": "Files",
      "description": "**Proxied → file-upload-service** (requires Bearer token)\n\nAll file storage is handled by the file-upload-service. Pass the following headers from your JWT claims:\n- `X-Tenant-Id` — `tenantId` from token\n- `X-User-Id` — `sub` from token\n- `X-User-Role` — `role` from token",
      "item": [
        {
          "name": "Upload File(s)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const r = pm.response.json();",
                  "  const id = r.data?.files?.[0]?._id || r.data?.file?._id;",
                  "  if (id) pm.collectionVariables.set('fileId', id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-Id", "value": "your-tenant-id", "description": "From JWT tenantId claim" },
              { "key": "X-User-Id", "value": "your-user-id", "description": "From JWT sub claim" },
              { "key": "X-User-Role", "value": "admin", "description": "From JWT role claim" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": [],
                  "description": "Select up to 10 files"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/files/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "files", "upload"]
            }
          }
        },
