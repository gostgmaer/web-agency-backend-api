# Auth service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, LOG_LEVEL, ENABLE_SWAGGER, CORS_ORIGINS, IAM_SERVICE_URL, FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL, NOTIFICATION_SERVICE_API_KEY, COOKIE_SECRET, SSO_SECRET) come from .env.shared.
# API_PREFIX is intentionally overridden here to keep IAM routes under /api/v1/iam.

PORT=3000
APP_NAME=user-auth-service
API_PREFIX=api/v1/iam
APP_URL=https://iam.easydev.in
AUTH_PUBLIC_BASE_URL=https://iam.easydev.in
AUTH_MODE=full

# Shared postgres instance, auth schema
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=auth

# Shared redis instance, auth db index
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_DB=0

# Feature flags
ENABLE_REDIS=true
ENABLE_BULLMQ=true
ENABLE_FILE_UPLOAD=true
ENABLE_EXPORTS=true
ENABLE_DB_QUERY_LOGGING=false
ENABLE_KAFKA=false
ENABLE_RATE_LIMIT=true

# Rate limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# JWT and SSO
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_REFRESH_SECRET
JWT_MAGIC_LINK_SECRET=CHANGE_ME_MAGIC_LINK_SECRET
JWT_PRIVATE_KEY=
JWT_PRIVATE_KEY_PATH=
IAM_JWT_PUBLIC_KEY_PATH=
JWT_PUBLIC_KEY_PATH=

# Integrations
FRONTEND_URL=https://easydev.in

# Social providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
APPLE_CLIENT_ID=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Kafka (optional)
KAFKA_BROKERS=
KAFKA_CLIENT_ID=
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
