# Auth service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, LOG_LEVEL, ENABLE_SWAGGER, CORS_ORIGINS, IAM_SERVICE_URL,
# FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL, NOTIFICATION_SERVICE_API_KEY, COOKIE_SECRET, SSO_SECRET,
# IAM_SSO_SECRET, TENANT_ID, TENANT_SLUG, JWT_SECRET, IAM_JWT_PUBLIC_KEY) come from .env.shared.
# API_PREFIX is intentionally overridden here to keep IAM routes under /api/v1/iam.

PORT=3000
APP_NAME=user-auth-service
API_PREFIX=api/v1/iam
APP_URL=https://iam.easydev.in
AUTH_PUBLIC_BASE_URL=https://iam.easydev.in
AUTH_MODE=full
ENABLE_LOGGING=true
LOG_LEVEL=info

# Shared postgres instance, auth schema
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=auth

# Shared redis instance, auth db index (db 0)
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_DB=0

# Feature flags
ENABLE_REDIS=true
ENABLE_BULLMQ=true
ENABLE_FILE_UPLOAD=true
ENABLE_EXPORTS=true
ENABLE_DB_QUERY_LOGGING=false
ENABLE_KAFKA=false
ENABLE_RATE_LIMIT=true

# Rate limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# RS256 asymmetric signing keys (base64-encoded PEM)
# JWT_PRIVATE_KEY signs tokens — keep secret, rotate on compromise
# JWT_PUBLIC_KEY verifies tokens — copy the value to IAM_JWT_PUBLIC_KEY in .env.shared and JWT_PUBLIC_KEY in all other service env files
JWT_PRIVATE_
JWT_PUBLIC_
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=
IAM_JWT_PUBLIC_KEY_PATH=

# JWT refresh and magic link secrets (IAM-only)
JWT_REFRESH_SECRET=sDSFwMDlK036BDr8Ev/IJgVd0UbPcmUcjqvKbv9S5BQ=
JWT_MAGIC_LINK_SECRET=ztj+xIK8+QIytubv4umPJA==

# Bootstrap accounts — auto-created by TenantBootstrapService on first boot (idempotent)
# Use the service-account credentials here for IAM_ADMIN_* in all other services
BOOTSTRAP_TENANT_NAME=EasyDev
BOOTSTRAP_SUPER_ADMIN_EMAIL=super-admin@example.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=CHANGE_ME_SUPER_ADMIN_PASSWORD
BOOTSTRAP_SERVICE_ACCOUNT_EMAIL=service-account@example.com
BOOTSTRAP_SERVICE_ACCOUNT_PASSWORD=CHANGE_ME_SERVICE_ACCOUNT_PASSWORD

# Integrations
FRONTEND_URL=https://easydev.in

# Social providers
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
APPLE_CLIENT_ID=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Kafka (disabled by default)
KAFKA_BROKERS=
KAFKA_CLIENT_ID=
KAFKA_SSL=false
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
