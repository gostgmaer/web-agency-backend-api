# Payment service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, LOG_LEVEL, API_PREFIX, IAM_SERVICE_URL, JWT_SECRET,
# IAM_JWT_PUBLIC_KEY, TENANT_ID, TENANT_SLUG, NOTIFICATION_SERVICE_URL, NOTIFICATION_SERVICE_API_KEY) come from .env.shared.

PORT=3000
APP_NAME=payment-microservice
ENABLE_LOGGING=true
LOG_LEVEL=info
ENABLE_SWAGGER=false
ENABLE_PINO_LOGGING=false

# Shared postgres instance, payment schema
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=payment

# Shared redis instance, payment db index (db 1 — IAM uses 0, gateway uses 3, AI Comm uses 2)
REDIS_DB=1

# RS256 public key — must match IAM_JWT_PUBLIC_KEY in .env.shared
# The payment service reads JWT_PUBLIC_KEY directly
JWT_PUBLIC_

# Internal IAM auth — service account credentials must match BOOTSTRAP_SERVICE_ACCOUNT_* in .env.auth
IAM_ADMIN_EMAIL=service-account@example.com
IAM_ADMIN_PASSWORD=CHANGE_ME_SERVICE_ACCOUNT_PASSWORD
# Static long-lived API key for IAM (used by permission registrar — must match IAM's issued key)
IAM_SERVICE_API_KEY=iam_d9bea739ebc9b65fb171b5d0da86d93b1894218629da83a49a6f03fabee9aabc
# SHA-256 hash of PAYMENT_SERVICE_API_KEY from .env.shared / .env.gateway
API_KEY_HASH=f08400e25c619067e96694d6dba836e122588f7a7bde0104384a0997fc410af7

# Logging and protection
ENABLE_RATE_LIMIT=true
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_RATE_LIMIT_TTL=60
WEBHOOK_RATE_LIMIT_MAX=30

# Feature toggles
FEATURE_MULTI_CURRENCY=false
FEATURE_FAILOVER_ENABLED=true
FEATURE_RECONCILIATION_ENABLED=true
BULLMQ_ENABLED=true

# Queue and retry behavior
PAYMENT_QUEUE_CONCURRENCY=5
REFUND_QUEUE_CONCURRENCY=3
SUBSCRIPTION_QUEUE_CONCURRENCY=5
SUBSCRIPTION_MAX_RETRY_ATTEMPTS=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
PAYMENT_ATTEMPT_EXPIRY_MINUTES=20
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400
MAX_RETRY_ATTEMPTS=3
RECONCILIATION_CRON=0 2 * * *

# Providers
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-04-10

RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=rzp_test_SiZPYJ5KTT0EbW
RAZORPAY_KEY_SECRET=KAvBBFY2ZIO66D3y96DZAEwk
RAZORPAY_WEBHOOK_SECRET=

# Cash is auto-enabled as fallback when Stripe+Razorpay are both disabled
CASH_ENABLED=true
