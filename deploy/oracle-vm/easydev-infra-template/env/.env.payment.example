# Payment service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, LOG_LEVEL, API_PREFIX, IAM_SERVICE_URL, JWT_SECRET, IAM_JWT_PUBLIC_KEY) come from .env.shared.

PORT=3000
APP_NAME=payment-microservice

# Shared postgres instance, payment schema
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=payment

# Shared redis instance, payment db index
REDIS_DB=1

# Internal auth integration
IAM_SERVICE_API_KEY=CHANGE_ME_IAM_SERVICE_API_KEY
API_KEY_HASH=CHANGE_ME_PAYMENT_API_KEY_HASH

# JWT validation/signing compatibility uses shared keys:
# - JWT_SECRET (HS256 fallback)
# - IAM_JWT_PUBLIC_KEY (RS256 preferred)

# Logging and protection
ENABLE_PINO_LOGGING=true
ENABLE_RATE_LIMIT=true
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100
WEBHOOK_RATE_LIMIT_TTL=60
WEBHOOK_RATE_LIMIT_MAX=30

# Feature toggles
FEATURE_MULTI_CURRENCY=true
FEATURE_FAILOVER_ENABLED=false
FEATURE_RECONCILIATION_ENABLED=true
BULLMQ_ENABLED=true

# Queue and retry behavior
PAYMENT_QUEUE_CONCURRENCY=5
REFUND_QUEUE_CONCURRENCY=3
SUBSCRIPTION_QUEUE_CONCURRENCY=3
SUBSCRIPTION_MAX_RETRY_ATTEMPTS=5
SUBSCRIPTION_RETRY_INTERVAL_HOURS=12
SUBSCRIPTION_GRACE_PERIOD_DAYS=7
PAYMENT_ATTEMPT_EXPIRY_MINUTES=20
PAYMENT_IDEMPOTENCY_TTL_SECONDS=86400
MAX_RETRY_ATTEMPTS=3
RECONCILIATION_CRON=0 */6 * * *

# Providers
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-04-10

RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional manual payment mode
CASH_ENABLED=true
