# AI Automation Communication service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, API_PREFIX, REDIS_HOST, REDIS_PORT, REDIS_PASSWORD,
# REDIS_ENABLED, CORS_ORIGINS, IAM_SERVICE_URL, JWT_SECRET, JWT_PUBLIC_KEY, TENANT_ID, TENANT_SLUG,
# IAM_SSO_SECRET, SSO_SECRET, COOKIE_SECRET, FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL,
# NOTIFICATION_SERVICE_API_KEY, DB_HOST, DB_PORT, DB_NAME, DB_USERNAME, DB_PASSWORD, DB_SSL) come from .env.shared.

PORT=3000
APP_URL=https://communication.easydev.in
FRONTEND_URL=https://communication.easydev.in
# EasyDev public site (used for onboarding redirects)
EASYDEV_URL=https://easydev.in
# Internal gateway URL — used for service-to-service calls (e.g. subscription sync)
EASYDEV_API_URL=http://gateway:3000/api/v1
ENABLE_LOGGING=true
LOG_LEVEL=info

# Shared postgres instance, ai_automation_communication schema
# Schema must match the one created by stacks/core/postgres-init/001-create-schemas.sql
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=ai_automation_communication
DB_SCHEMA=ai_automation_communication
# TypeORM synchronize: keep true so entity changes auto-migrate on deploy
DB_SYNCHRONIZE=true

# Shared redis instance, AI Comm db index (db 2)
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/2

# IAM integration
IAM_PUBLIC_HOST=https://iam.easydev.in
IAM_APPLICATION_ID=
# Must match the IAM application slug registered in multi-tannet-auth-services
IAM_APPLICATION_SLUG=easydev-ai-communication
COMMUNICATION_IAM_APPLICATION_SLUG=easydev-ai-communication
COMMUNICATION_IAM_TENANT_SLUG=easydev
COMMUNICATION_IAM_DEFAULT_ROLE=member
# Service-account credentials — must match BOOTSTRAP_SERVICE_ACCOUNT_* in .env.auth
IAM_ADMIN_EMAIL=service-account@example.com
IAM_ADMIN_PASSWORD=CHANGE_ME_SERVICE_ACCOUNT_PASSWORD
IAM_ADMIN_JWT=

# RS256 public key — must match JWT_PUBLIC_KEY in .env.shared
JWT_PUBLIC_

# Service-to-service API key
# Must match COMMUNICATION_API_KEY in .env.gateway
SALES_API_KEY=da63ae28aa21c9cf7d4a056f97a93771a8c2ad76548a33db596fb20cecb47936

# Internal controls
ENABLE_BULLMQ=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Credential encryption key — used to encrypt OAuth tokens and provider API keys stored in DB
# IMPORTANT: never change this after first boot (existing encrypted data will become unreadable)
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX_ENCRYPTION_KEY

# SMTP (optional — email replies sent via configured email accounts, not SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@easydev.in
SMTP_FROM_NAME=EasyDev

# AI providers — tried in order, first with a valid key wins
# Free tier
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/owl-alpha

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=llama3.1-8b

# Premium fallback — used only when all free providers fail or are unconfigured
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# OAuth providers — redirect URIs must point to the production hostname
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=https://communication.easydev.in/api/v1/email-accounts/oauth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://communication.easydev.in/api/v1/email-accounts/oauth/microsoft/callback

YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_OAUTH_REDIRECT_URI=https://communication.easydev.in/api/v1/email-accounts/oauth/yahoo/callback

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=https://communication.easydev.in/api/v1/email-accounts/oauth/zoho/callback
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_MAIL_API_BASE_URL=

# Messaging
WHATSAPP_API_VERSION=v18.0
WHATSAPP_VERIFY_TOKEN=

# Optional legacy / migration key
MONGODB_URI=
