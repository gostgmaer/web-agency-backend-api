# AI Automation Communication service-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, API_PREFIX, REDIS_*, CORS_ORIGINS, IAM_SERVICE_URL, JWT_SECRET, IAM_JWT_PUBLIC_KEY, TENANT_ID, TENANT_SLUG, IAM_SSO_SECRET, FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL, NOTIFICATION_SERVICE_API_KEY, COOKIE_SECRET, DB_HOST, DB_PORT, DB_NAME, DB_USERNAME, DB_PASSWORD, DB_SSL, DB_SYNCHRONIZE) come from .env.shared.

PORT=3000
APP_URL=https://communication.easydev.in
FRONTEND_URL=https://communication.easydev.in
EASYDEV_URL=https://easydev.in
EASYDEV_API_URL=http://gateway:3000

# Shared postgres instance, ai_automation_communication schema
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_POSTGRES_PASSWORD@postgres:5432/easydev?schema=ai_automation_communication
DB_SCHEMA=ai_automation_communication

# Shared redis instance, dedicated db index
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/2

# IAM integration
IAM_PUBLIC_HOST=https://iam.easydev.in
IAM_APPLICATION_ID=CHANGE_ME_APPLICATION_ID
IAM_APPLICATION_SLUG=ai-automation-communication
IAM_ADMIN_EMAIL=admin@easydev.in
IAM_ADMIN_PASSWORD=CHANGE_ME_IAM_ADMIN_PASSWORD
IAM_ADMIN_JWT=

# Product provisioning alignment
COMMUNICATION_IAM_APPLICATION_SLUG=ai-automation-communication
COMMUNICATION_IAM_DEFAULT_ROLE=customer

# JWT validation key comes from .env.shared (JWT_SECRET)

# Service integrations
SALES_API_KEY=CHANGE_ME_SALES_API_KEY

# Internal controls
ENABLE_BULLMQ=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_ENCRYPTION_KEY

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@easydev.in
SMTP_FROM_NAME=EasyDev

# AI providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_OAUTH_REDIRECT_URI=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_OAUTH_REDIRECT_URI=
ZOHO_ACCOUNTS_BASE_URL=
ZOHO_MAIL_API_BASE_URL=

# Messaging
WHATSAPP_API_VERSION=v18.0
WHATSAPP_VERIFY_TOKEN=

# Optional legacy / migration key
MONGODB_URI=
