# Gateway-specific settings.
# Common values (NODE_ENV, JWT_ISSUER, JWT_AUDIENCE, LOG_LEVEL, ENABLE_LOGGING, ENABLE_SWAGGER, API_PREFIX,
# REQUEST_TIMEOUT, SHUTDOWN_TIMEOUT, CORS_ORIGINS, FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL,
# NOTIFICATION_SERVICE_API_KEY, TENANT_ID, TENANT_SLUG, PAYMENT_SERVICE_URL, PAYMENT_SERVICE_API_KEY,
# IAM_SERVICE_URL, IAM_SSO_SECRET, COOKIE_SECRET) come from .env.shared.

PORT=3000
APP_NAME=web-agency-backend-api
CLUSTER_MODE=false
DISABLE_FILE_LOGGING=false
NPM_PACKAGE_VERSION=0.0.0
FRONTEND_URL=https://easydev.in
DASHBOARD_URL=https://easydev.in

# Public ingress port exposed on Oracle VM host
GATEWAY_PUBLIC_PORT=80

# RS256 public key — must match IAM_JWT_PUBLIC_KEY in .env.shared
# The gateway middleware reads JWT_PUBLIC_KEY (not IAM_JWT_PUBLIC_KEY)
JWT_PUBLIC_

# Internal upstreams via Docker DNS on easydev-net
AUTH_SERVICE_URL=http://auth-service:3000
COMMUNICATION_URL=http://ai-automation-communication-service:3000/api/v1

# Gateway auth and provisioning integration
# COMMUNICATION_API_KEY must match SALES_API_KEY in .env.ai-automation-communication
COMMUNICATION_API_KEY=da63ae28aa21c9cf7d4a056f97a93771a8c2ad76548a33db596fb20cecb47936
# Must match IAM application slug registered in multi-tannet-auth-services
COMMUNICATION_IAM_APPLICATION_SLUG=easydev-ai-communication
COMMUNICATION_IAM_TENANT_SLUG=easydev
COMMUNICATION_IAM_DEFAULT_ROLE=member

# IAM service-account credentials — must match BOOTSTRAP_SERVICE_ACCOUNT_* in .env.auth
# The gateway uses a service account (not a human admin) for privileged IAM calls
IAM_ADMIN_EMAIL=service-account@example.com
IAM_ADMIN_PASSWORD=CHANGE_ME_SERVICE_ACCOUNT_PASSWORD
IAM_ADMIN_JWT=
IAM_TENANT_SLUG=easydev

# Email defaults
FROM_EMAIL=noreply@easydev.in
FROM_NAME=EasyDev

# Payment gateway public key (returned to frontend checkout UI — not the secret)
RAZORPAY_KEY_ID=rzp_test_SiZPYJ5KTT0EbW

# Optional redis cache for gateway paths (db index 3)
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/3

# Optional legacy keys
MONGODB_URI=
ADMIN_EMAIL=admin@easydev.in
