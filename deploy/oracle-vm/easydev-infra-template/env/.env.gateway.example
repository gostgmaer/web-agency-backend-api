# Gateway-specific settings.
# Common values (NODE_ENV, JWT_*, LOG_LEVEL, ENABLE_LOGGING, ENABLE_SWAGGER, API_PREFIX, REQUEST_TIMEOUT, SHUTDOWN_TIMEOUT, CORS_ORIGINS, FILE_UPLOAD_SERVICE_URL, NOTIFICATION_SERVICE_URL, NOTIFICATION_SERVICE_API_KEY, TENANT_ID, TENANT_SLUG, PAYMENT_SERVICE_URL, PAYMENT_SERVICE_API_KEY) come from .env.shared.

PORT=3000
APP_NAME=web-agency-backend-api
CLUSTER_MODE=false
DISABLE_FILE_LOGGING=false
NPM_PACKAGE_VERSION=0.0.0
FRONTEND_URL=https://easydev.in

# Public ingress port exposed on Oracle VM host
GATEWAY_PUBLIC_PORT=80

# Internal upstreams via Docker DNS on easydev-net
AUTH_SERVICE_URL=http://auth-service:3000
COMMUNICATION_URL=http://ai-automation-communication-service:3000/api/v1

# Gateway auth and provisioning integration
COMMUNICATION_API_KEY=CHANGE_ME_COMMUNICATION_API_KEY
COMMUNICATION_IAM_APPLICATION_SLUG=ai-automation-communication
COMMUNICATION_IAM_DEFAULT_ROLE=customer

# Admin provisioning defaults
ADMIN_EMAIL=admin@easydev.in
IAM_ADMIN_EMAIL=admin@easydev.in
IAM_ADMIN_PASSWORD=CHANGE_ME_IAM_ADMIN_PASSWORD
IAM_ADMIN_JWT=

# Messaging and payment adapters
FROM_EMAIL=noreply@easydev.in
FROM_NAME=EasyDev
RAZORPAY_KEY_ID=

# Optional redis cache for gateway paths
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/3

# Optional legacy key kept for compatibility
MONGODB_URI=
