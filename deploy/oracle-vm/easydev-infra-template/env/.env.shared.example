# Shared runtime configuration loaded by all services.
# Keep only truly common values here. Service-specific files override when needed.

# Runtime baseline
NODE_ENV=production
TZ=UTC
LOG_LEVEL=info
ENABLE_LOGGING=true
ENABLE_SWAGGER=false
API_PREFIX=api/v1

# Shared ingress/security policy
CORS_ORIGINS=https://easydev.in,https://www.easydev.in,https://communication.easydev.in

# Public URLs
PUBLIC_BASE_URL=https://api.easydev.in
DASHBOARD_URL=https://easydev.in

# Common operational defaults
REQUEST_TIMEOUT=30000
SHUTDOWN_TIMEOUT=10000

# Shared service endpoints and tenant defaults
# Internal Docker DNS — all services are on easydev-net
IAM_SERVICE_URL=http://auth-service:3000
PAYMENT_SERVICE_URL=http://payment-service:3000
# Plaintext key whose SHA-256 hash must match payment service API_KEY_HASH
PAYMENT_SERVICE_API_KEY=payment_dev_api_key_32chars_change_me
FILE_UPLOAD_SERVICE_URL=https://file-upload-service-zjtv.onrender.com
FILE_UPLOAD_SERVICE_HEALTH_URL=https://file-upload-service-zjtv.onrender.com/health
NOTIFICATION_SERVICE_URL=https://notification-service-iota.vercel.app/v1
NOTIFICATION_SERVICE_HEALTH_URL=https://notification-service-iota.vercel.app/v1/health
NOTIFICATION_SERVICE_API_KEY=kG54mOvH_bfy1gMsdX8LItgehLhyS86H6QWXaBWKAbgqvyBVcz0HOJbs3e9eTuxnZ8CL7kFXfXTAteO3nqdRWg
TENANT_ID=easydev
TENANT_SLUG=easydev

# Shared auth/session secrets used by multiple services
# IAM_SSO_SECRET and SSO_SECRET must be identical — used by IAM to sign and AI Comm to verify SSO tokens
IAM_SSO_SECRET=AeqgtMpxvt+tRbCT5ygUiA==
SSO_SECRET=AeqgtMpxvt+tRbCT5ygUiA==
# COOKIE_SECRET is used by cookie-parser in IAM and AI Comm — must be a random string, shared for consistency
COOKIE_SECRET=Fgt0Ej6j0/78OHq+lH7x9u7D8puBwfiFSeKpPG5ZweI=

# Shared DB connection primitives for services that use DB_* vars directly.
# DB_SCHEMA remains service specific and must stay in service env files.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=easydev
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DB_SSL=false
DB_SYNCHRONIZE=false

# Shared PostgreSQL primitives (single database, schema-per-service)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easydev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Shared Redis primitives (single redis, db-per-service)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# Shared JWT contract
# JWT_ISSUER must match the public URL of the auth service (used as `iss` claim in all tokens)
JWT_ISSUER=https://iam.easydev.in
JWT_AUDIENCE=easydev
# HS256 shared fallback secret — must be identical across all services
JWT_SECRET=hQ3gWIb3VhbmeSXD1y+JJJckE73X8nspsQEaixUO0ccY4oHU8KvFeL9Y8vGsdigvJJimbnAjcWbHGORX8DTKug==
# RS256 public key (base64-encoded SPKI PEM) — generated by IAM, copied to all verifying services
JWT_PUBLIC_

# NOTE:
# JWT_REFRESH_SECRET is auth-service specific and is intentionally kept in .env.auth.
# Legacy aliases kept in some services for backward compatibility:
# - JWT_ACCESS_SECRET should equal JWT_SECRET
