# Shared runtime configuration loaded by all services.
# Keep only truly common values here. Service-specific files override when needed.

# Runtime baseline
NODE_ENV=production
TZ=UTC
LOG_LEVEL=debug
ENABLE_LOGGING=true
ENABLE_SWAGGER=true
API_PREFIX=api/v1

# Shared ingress/security policy
CORS_ORIGINS=https://easydev.in,https://www.easydev.in

# Public URLs
PUBLIC_BASE_URL=https://api.easydev.in
DASHBOARD_URL=https://app.easydev.in

# Common operational defaults
REQUEST_TIMEOUT=30000
SHUTDOWN_TIMEOUT=10000

# Shared service endpoints and tenant defaults
IAM_SERVICE_URL=http://auth-service:3000
PAYMENT_SERVICE_URL=http://payment-service:3000
# Plaintext key whose SHA-256 hash must match payment service API_KEY_HASH
PAYMENT_SERVICE_API_KEY=CHANGE_ME_PAYMENT_SERVICE_API_KEY
FILE_UPLOAD_SERVICE_URL=http://file-upload-service:3000/api/v1
FILE_UPLOAD_SERVICE_HEALTH_URL=http://file-upload-service:3000/health
NOTIFICATION_SERVICE_URL=http://notification-service:3000/api/v1
NOTIFICATION_SERVICE_HEALTH_URL=http://notification-service:3000/health
NOTIFICATION_SERVICE_API_KEY=CHANGE_ME_NOTIFICATION_SERVICE_API_KEY
TENANT_ID=CHANGE_ME_TENANT_ID
TENANT_SLUG=CHANGE_ME_TENANT_ID

# Shared auth/session secrets used by multiple services
IAM_SSO_SECRET=CHANGE_ME_SSO_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET
SSO_SECRET=CHANGE_ME_SSO_SECRET

# Shared DB connection primitives for services that use DB_* vars directly.
# DB_SCHEMA remains service specific and must stay in service env files.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=easydev
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
DB_SSL=false
DB_SYNCHRONIZE=false

# Shared PostgreSQL primitives (single database, schema-per-service)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=easydev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# Shared Redis primitives (single redis, db-per-service)
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# Shared JWT contract
JWT_ISSUER=user-auth-service
JWT_AUDIENCE=dashboard-app
JWT_SECRET=CHANGE_ME_SHARED_JWT_SECRET
IAM_JWT_PUBLIC_KEY=

# NOTE:
# JWT_REFRESH_SECRET is auth-service specific and is intentionally kept in .env.auth.
# Legacy aliases kept in some services for backward compatibility:
# - JWT_ACCESS_SECRET should equal JWT_SECRET
# - IAM_JWT_SECRET should equal JWT_SECRET
