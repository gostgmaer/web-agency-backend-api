# Shared database for auth + payment
CORE_POSTGRES_USER=core_user
CORE_POSTGRES_PASSWORD=change_me_core_db_password
CORE_POSTGRES_DB=platform_core

# Local image references (workflows upload and load images directly on VM)
IAM_IMAGE=easydev-iam-platform:latest
IAM_IMAGE_BACKUP=easydev-iam-platform:backup
PAYMENT_IMAGE=easydev-payment-service:latest
PAYMENT_IMAGE_BACKUP=easydev-payment-service:backup

# Shared JWT + SSO secrets (must match across IAM, payment, gateway, communication)
# [prod] generate: openssl rand -hex 64
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_MAGIC_LINK_SECRET=change_me_magic_link_secret_min_32_chars
SSO_SECRET=change_me_sso_secret_min_16_chars
COOKIE_SECRET=change_me_cookie_secret_min_32_chars
#
# JWT issuer claim written into every access token — must equal JWT_ISSUER in ALL downstream services.
JWT_ISSUER=https://iam.example.com
#
# RS256 asymmetric key pair (recommended for production over HS256 JWT_SECRET).
# When set, IAM signs tokens with RS256. Downstream services only need JWT_PUBLIC_KEY.
# Generate:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out jwtRS256.key
#   openssl rsa -pubout -in jwtRS256.key -out jwtRS256.key.pub
# Encode to base64 (single line):
#   base64 -w0 jwtRS256.key      -> paste into JWT_PRIVATE_KEY
#   base64 -w0 jwtRS256.key.pub  -> paste into JWT_PUBLIC_KEY (also copy to .env.apps)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# IAM bootstrap defaults
FRONTEND_URL=https://frontend.example.com
COOKIE_DOMAIN=.example.com
BOOTSTRAP_ACCOUNTS_ENABLED=true
BOOTSTRAP_DEFAULT_TENANT_NAME=Default Tenant
BOOTSTRAP_DEFAULT_TENANT_SLUG=default
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@iam.example.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=change_me_super_admin_password
BOOTSTRAP_TENANT_ADMIN_EMAIL=tenant.admin@iam.example.com
BOOTSTRAP_TENANT_ADMIN_PASSWORD=change_me_tenant_admin_password
BOOTSTRAP_SAMPLE_APPS_ENABLED=true
BOOTSTRAP_SAMPLE_GRANTS_ENABLED=true
AI_COMMUNICATION_FRONTEND_URL=https://communication.example.com
AI_COMMUNICATION_ALLOWED_ORIGINS=https://communication.example.com,https://gateway.example.com

# IAM integrations
FILE_UPLOAD_SERVICE_URL=https://files.example.com
NOTIFICATION_SERVICE_URL=https://notification.example.com/v1
NOTIFICATION_SERVICE_API_KEY=change_me_notification_api_key
NOTIFICATION_TENANT_ID=platform
ENABLE_REDIS=true
ENABLE_BULLMQ=true
ENABLE_KAFKA=false
ENABLE_SWAGGER=false

# IAM social auth optional values
APP_URL=https://iam.example.com
AUTH_PUBLIC_BASE_URL=https://iam.example.com/api/v1/iam/auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment service security
# SHA-256 hash of PAYMENT_SERVICE_API_KEY used by gateway (.env.apps)
API_KEY_HASH=change_me_sha256_hash_of_gateway_payment_service_api_key
IAM_SERVICE_API_KEY=

# Payment providers (configure only what you use)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CASH_ENABLED=true

# Logging / runtime
LOG_LEVEL=info
ENABLE_PINO_LOGGING=false
