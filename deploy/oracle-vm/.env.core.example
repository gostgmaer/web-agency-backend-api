# Shared database for auth + payment
CORE_POSTGRES_USER=core_user
CORE_POSTGRES_PASSWORD=change_me_core_db_password
CORE_POSTGRES_DB=easydev_core

# Registry image references
IAM_IMAGE=docker.io/your-dockerhub-namespace/easydev-iam-service:latest
IAM_IMAGE_BACKUP=docker.io/your-dockerhub-namespace/easydev-iam-service:backup
PAYMENT_IMAGE=docker.io/your-dockerhub-namespace/easydev-payment-service:latest
PAYMENT_IMAGE_BACKUP=docker.io/your-dockerhub-namespace/easydev-payment-service:backup

# Shared JWT + SSO secrets (must match across IAM, payment, gateway, communication)
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_MAGIC_LINK_SECRET=change_me_magic_link_secret_min_32_chars
SSO_SECRET=change_me_sso_secret_min_16_chars
COOKIE_SECRET=change_me_cookie_secret_min_32_chars

# IAM bootstrap defaults
FRONTEND_URL=http://155.248.244.237:3000
COOKIE_DOMAIN=155.248.244.237
BOOTSTRAP_ACCOUNTS_ENABLED=true
BOOTSTRAP_DEFAULT_TENANT_NAME=EasyDev
BOOTSTRAP_DEFAULT_TENANT_SLUG=easydev
BOOTSTRAP_SUPER_ADMIN_EMAIL=admin@easydev.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=change_me_super_admin_password
BOOTSTRAP_TENANT_ADMIN_EMAIL=tenant.admin@easydev.com
BOOTSTRAP_TENANT_ADMIN_PASSWORD=change_me_tenant_admin_password
BOOTSTRAP_SAMPLE_APPS_ENABLED=true
BOOTSTRAP_SAMPLE_GRANTS_ENABLED=true
AI_COMMUNICATION_FRONTEND_URL=http://155.248.244.237:3002
AI_COMMUNICATION_ALLOWED_ORIGINS=http://155.248.244.237:3002,http://155.248.244.237:3500

# IAM integrations
FILE_UPLOAD_SERVICE_URL=https://file-upload-service-zjtv.onrender.com
NOTIFICATION_SERVICE_URL=https://notification-service-iota.vercel.app/v1
NOTIFICATION_SERVICE_API_KEY=change_me_notification_api_key
NOTIFICATION_TENANT_ID=Easydev
ENABLE_REDIS=true
ENABLE_BULLMQ=true
ENABLE_KAFKA=false
ENABLE_SWAGGER=false

# IAM social auth optional values
APP_URL=http://155.248.244.237:3100
AUTH_PUBLIC_BASE_URL=http://155.248.244.237:3500/api/auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Payment service security
# SHA-256 hash of PAYMENT_SERVICE_API_KEY used by gateway (.env.apps)
API_KEY_HASH=change_me_sha256_hash_of_gateway_payment_service_api_key
IAM_SERVICE_API_KEY=

# Payment providers (configure only what you use)
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CASH_ENABLED=true

# Logging / runtime
LOG_LEVEL=info
ENABLE_PINO_LOGGING=false
