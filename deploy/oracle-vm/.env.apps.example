# AI Communication uses shared core Postgres/Redis from .env.core
# AI communication tables are isolated in this schema inside CORE_POSTGRES_DB
COMM_DB_SCHEMA=communication

# Local image references (workflows upload and load images directly on VM)
COMMUNICATION_IMAGE=easydev-ai-communication-backend:latest
COMMUNICATION_IMAGE_BACKUP=easydev-ai-communication-backend:backup
EDGE_PROXY_IMAGE=caddy:2.9-alpine
ENABLE_EDGE_PROXY=true

# Port allocation policy
# Containers bind to their configured PORT; nginx on the host terminates 80/443
# and reverse-proxies to each container by path/host.
# Default container ports: 3500=gateway, 3100=IAM, 4000=payment, 4001=AI-comm
# These ports are reachable from each other via Docker service DNS on easydev-services network.

# Public domain routing
GATEWAY_PUBLIC_HOST=gateway.example.com
IAM_PUBLIC_HOST=iam.example.com
PAYMENT_PUBLIC_HOST=payments.example.com

# IAM and Payment are publicly exposed via their own hostnames.

# Gateway required secrets and external dependencies
MONGODB_URI=replace_with_existing_cloud_mongodb_uri
FRONTEND_URL=https://frontend.example.com
# [prod] include apex + www + all product frontends
CORS_ORIGINS=https://frontend.example.com,https://www.frontend.example.com,https://dashboard.example.com
#
# JWT verification --- tokens are issued by IAM, verified here.
# Option A (recommended): RS256 public key --- copy IAM_JWT_PUBLIC_KEY from .env.core (base64 SPKI PEM)
IAM_JWT_PUBLIC_KEY=
JWT_PUBLIC_KEY=
# Option B (fallback): HS256 shared secret --- must match JWT_SECRET in .env.core
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ACCESS_SECRET=
# Must exactly match JWT_ISSUER in IAM (.env.core): typically https://iam.example.com
JWT_ISSUER=https://iam.example.com
JWT_AUDIENCE=dashboard-app

NOTIFICATION_SERVICE_URL=https://notification.example.com
NOTIFICATION_SERVICE_API_KEY=change_me_notification_api_key
NOTIFICATION_SERVICE_HEALTH_URL=https://notification.example.com/v1/health

FILE_UPLOAD_SERVICE_URL=https://files.example.com
FILE_UPLOAD_SERVICE_HEALTH_URL=https://files.example.com/health

TENANT_ID=your_tenant_slug
DASHBOARD_URL=https://dashboard.example.com
REDIS_ENABLED=true
REDIS_URL=redis://redis-core:3305

# Payment adapter key (plaintext)
# Must hash to API_KEY_HASH in .env.core
PAYMENT_SERVICE_API_KEY=change_me_payment_plaintext_api_key

# AI Communication shared API key
# Must be the same value as SALES_API_KEY below
COMMUNICATION_API_KEY=change_me_shared_communication_api_key

# IAM admin credentials for provisioning (used by gateway + communication)
IAM_ADMIN_EMAIL=service-account-iam@iam.local
IAM_ADMIN_PASSWORD=change_me_iam_service_password
IAM_ADMIN_JWT=
IAM_TENANT_SLUG=your_tenant_slug
COMMUNICATION_IAM_TENANT_SLUG=your_tenant_slug
# Communication IAM app slug and role are defined in gateway config.products

# Gateway checkout key exposed to frontend
RAZORPAY_KEY_ID=

# Communication backend required secrets
COOKIE_SECRET=change_me_cookie_secret_min_32_chars
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_ISSUER=https://iam.example.com
JWT_AUDIENCE=dashboard-app
# RS256 public key for IAM access-token verification (preferred over HS256 IAM_JWT_SECRET)
# Copy IAM_JWT_PUBLIC_KEY from .env.core (base64-encoded SPKI PEM)
IAM_JWT_PUBLIC_KEY=
IAM_JWT_SECRET=
IAM_SSO_SECRET=change_me_sso_secret_min_16_chars
SALES_API_KEY=change_me_shared_communication_api_key
ENCRYPTION_KEY=change_me_32_char_encryption_key

# Communication app URL config
FRONTEND_URL=https://communication.example.com
EASYDEV_URL=https://frontend.example.com

# Optional provider keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
TENANT_SLUG=your_tenant_slug
API_PREFIX=api/v1
ENABLE_SWAGGER=true
ENABLE_LOGGING=true
LOG_LEVEL=info

