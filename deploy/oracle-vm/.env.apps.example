# Communication database and redis
COMM_POSTGRES_USER=comm_user
COMM_POSTGRES_PASSWORD=change_me_comm_db_password
COMM_POSTGRES_DB=easydev_communication

# Local image references (workflows upload and load images directly on VM)
GATEWAY_IMAGE=easydev-gateway:latest
GATEWAY_IMAGE_BACKUP=easydev-gateway:backup
COMMUNICATION_IMAGE=easydev-ai-communication-backend:latest
COMMUNICATION_IMAGE_BACKUP=easydev-ai-communication-backend:backup
EDGE_PROXY_IMAGE=caddy:2.9-alpine

# Public domain routing
IAM_PUBLIC_HOST=iam-service.easydev.in
PAYMENT_PUBLIC_HOST=payment.easydev.in
GATEWAY_PUBLIC_HOST=gateway-server.easydev.in

# Gateway required secrets and external dependencies
MONGODB_URI=replace_with_existing_cloud_mongodb_uri
FRONTEND_URL=http://155.248.244.237:3000
CORS_ORIGINS=http://155.248.244.237:3000,http://155.248.244.237:3002
JWT_ACCESS_SECRET=change_me_jwt_secret_min_32_chars
JWT_ISSUER=user-auth-service
JWT_AUDIENCE=dashboard-app

EMAIL_SERVICE_URL=https://notification-service-iota.vercel.app
EMAIL_SERVICE_API_KEY=change_me_notification_api_key
NOTIFICATION_SERVICE_HEALTH_URL=https://notification-service-iota.vercel.app/v1/health

FILE_UPLOAD_SERVICE_URL=https://file-upload-service-zjtv.onrender.com
FILE_UPLOAD_SERVICE_HEALTH_URL=https://file-upload-service-zjtv.onrender.com/health

TENANT_ID=easydev
DASHBOARD_URL=http://155.248.244.237:3002
REDIS_ENABLED=true
REDIS_URL=redis://redis-comm:6379

# Payment adapter key (plaintext)
# Must hash to API_KEY_HASH in .env.core
PAYMENT_SERVICE_API_KEY=change_me_payment_plaintext_api_key

# AI Communication shared API key
# Must be the same value as SALES_API_KEY below
COMMUNICATION_API_KEY=change_me_shared_communication_api_key

# IAM admin credentials for provisioning (used by gateway + communication)
IAM_ADMIN_EMAIL=service-account-iam@iam.local
IAM_ADMIN_PASSWORD=change_me_iam_service_password
IAM_ADMIN_JWT=
IAM_TENANT_SLUG=easydev
COMMUNICATION_IAM_APPLICATION_SLUG=easydev-ai-communication
COMMUNICATION_IAM_TENANT_SLUG=easydev
COMMUNICATION_IAM_DEFAULT_ROLE=member

# Gateway checkout key exposed to frontend
RAZORPAY_KEY_ID=

# Communication backend required secrets
COOKIE_SECRET=change_me_cookie_secret_min_32_chars
JWT_SECRET=change_me_jwt_secret_min_32_chars
IAM_JWT_SECRET=change_me_jwt_secret_min_32_chars
IAM_SSO_SECRET=change_me_sso_secret_min_16_chars
SALES_API_KEY=change_me_shared_communication_api_key
ENCRYPTION_KEY=change_me_32_char_encryption_key

# Communication app URL config
FRONTEND_URL=http://155.248.244.237:3002
EASYDEV_URL=http://155.248.244.237:3000

# Optional provider keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
